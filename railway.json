{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "healthcheckPath": "/robots.txt",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "cron": {
    "juya-check-morning": {
      "command": "curl -X POST https://ai-pulse-production.up.railway.app/api/cron/juya-check -H 'Content-Type: application/json' -H 'Authorization: Bearer ${CRON_SECRET}'",
      "schedule": "30 8 * * *"
    },
    "juya-check-midday": {
      "command": "curl -X POST https://ai-pulse-production.up.railway.app/api/cron/juya-check -H 'Content-Type: application/json' -H 'Authorization: Bearer ${CRON_SECRET}'",
      "schedule": "0 9 * * *"
    },
    "juya-check-late": {
      "command": "curl -X POST https://ai-pulse-production.up.railway.app/api/cron/juya-check -H 'Content-Type: application/json' -H 'Authorization: Bearer ${CRON_SECRET}'",
      "schedule": "30 9 * * *"
    },
    "leaderboard-weekly": {
      "command": "curl -X POST https://ai-pulse-production.up.railway.app/api/leaderboard/fetch -H 'Content-Type: application/json' -H 'Authorization: Bearer ${CRON_SECRET}'",
      "schedule": "0 9 * * 1"
    }
  }
}
