{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && pnpm next build"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "pnpm next start -p $PORT",
    "healthcheckPath": "/api/hot",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
